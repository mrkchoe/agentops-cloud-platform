# Core
APP_ENV=development

# Backend
API_AUTH_TOKEN=dev-demo-token
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/agentops_cloud
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# LLM
LLM_PROVIDER=mock
OPENAI_API_KEY=

# Seeds
SEED_DEMO=1

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_AUTH_TOKEN=dev-demo-token
NEXT_PUBLIC_USER_ID=1

